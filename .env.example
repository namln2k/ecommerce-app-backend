# App
NODE_ENV=development
PORT=3000

# Postgres (used to build DATABASE_URL inside compose.yaml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ecommerce_app

# Full connection string — compose.yaml overrides the host to "postgres"
# for the app container. If running the app outside Docker, point this at
# localhost instead.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ecommerce_app

# Redis — compose.yaml overrides the host to "redis" for the app container.
REDIS_URL=redis://localhost:6379

# Kafka — compose.yaml overrides this to the internal Docker broker address.
KAFKA_BROKERS=localhost:9092

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-string
JWT_REFRESH_EXPIRES_IN=7d
