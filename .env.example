# App
NODE_ENV=development
PORT=3000

# Postgres (used to build DATABASE_URL inside docker-compose.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=booking_app

# Full connection string — docker-compose.yml overrides the host to "postgres"
# for the app container. If running the app outside Docker, point this at
# localhost instead.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/booking_app

# Redis — docker-compose.yml overrides the host to "redis" for the app container.
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=15m
